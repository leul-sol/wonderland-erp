APP_NAME="Wonderland ERP Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Portal uses Redis session only — no business DB.
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=redis
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=sync

REDIS_CLIENT=phpredis
REDIS_HOST=wh-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Internal gateway URL (Docker network). Browser uses http://localhost/
GATEWAY_INTERNAL_URL=http://wh-gateway

PORTAL_TOKEN_REFRESH_BUFFER=120

VITE_APP_NAME="${APP_NAME}"
