# Wonderland ERP platform secrets (copy to .env at repo root).
# Required before any shared/staging host — never commit .env.
#
# Local dev: omit .env and docker compose uses the :-fallback defaults below.
# Staging: copy this file to .env, replace every value, then docker compose up -d --build

# Service-to-service auth (X-Service-Key header)
INTERNAL_KEY_CURRENT=wh-staging-svc-k7Qm9xP2vL4nR8wT

# MySQL (must match mysql-init grants and all service DB_PASSWORD)
# After changing DB_PASSWORD on an existing volume, run: docker compose down -v
MYSQL_ROOT_PASSWORD=wh-mysql-root-K9pL2mN7xQ
DB_PASSWORD=wh-db-app-H3jK8nM2pR

# S1 super.admin (only applied on first seed; existing DB keeps prior hash)
SUPER_ADMIN_PASSWORD=WhStaging!2026#Admin

# Optional: UAT / Postman gateway host (default 127.0.0.1)
# GATEWAY_HOST=127.0.0.1

# Ops — backup (scripts/backup-mysql.ps1, docker-compose.ops.yml)
# BACKUP_INTERVAL_HOURS=24
# BACKUP_RETENTION_DAYS=14

# Ops — monitoring (scripts/monitor-stack.ps1, wh-monitor profile)
# MONITOR_INTERVAL_SECONDS=60
# FAILED_OUTBOX_THRESHOLD=1
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
