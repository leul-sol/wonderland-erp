{
  "info": {
    "_postman_id": "wonderland-s1-identity-v1",
    "name": "Wonderland ERP — S1 Identity & Access",
    "description": "S1 Identity & Access API via local gateway.\n\n**Setup**\n1. Import `Wonderland-S1-Local.postman_environment.json` (or set variables below).\n2. Run **Auth → Login** — tokens are saved automatically.\n3. Use other requests with Bearer auth.\n\n**Defaults (dev)**\n- Base URL: `http://localhost/s1/api/v1`\n- Username: `super.admin`\n- Password: `ChangeMeNow!10`\n- Service key: `dev-internal-key-change-in-prod`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost/s1/api/v1" },
    { "key": "serviceKey", "value": "dev-internal-key-change-in-prod" },
    { "key": "username", "value": "super.admin" },
    { "key": "password", "value": "ChangeMeNow!10" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "roleId", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "S1 Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.access_token);",
                  "  pm.collectionVariables.set('refreshToken', body.refresh_token);",
                  "  pm.test('Login succeeded', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.access_token);",
                  "  pm.collectionVariables.set('refreshToken', body.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"{{password}}\",\n  \"password\": \"NewSecurePass!10\",\n  \"password_confirmation\": \"NewSecurePass!10\"\n}"
            },
            "url": "{{baseUrl}}/auth/change-password"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "JWKS (public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/jwks"
          }
        },
        {
          "name": "Verify Token (service key)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Service-Key", "value": "{{serviceKey}}" }
            ],
            "url": "{{baseUrl}}/auth/verify"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users?per_page=25&search=",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "per_page", "value": "25" },
                { "key": "search", "value": "" },
                { "key": "is_active", "value": "true", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "List Users (service key)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Service-Key", "value": "{{serviceKey}}" }],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('userId', pm.response.json().data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"frontdesk.user\",\n  \"email\": \"frontdesk@wonderlandhotel.local\",\n  \"password\": \"Welcome123!\",\n  \"display_name\": \"Front Desk User\",\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Update User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"Front Desk User (updated)\",\n  \"employee_id\": 1001\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Assign Roles",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roles\": [\n    { \"role_id\": {{roleId}}, \"department_id\": null }\n  ]\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/roles"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"TempPass123!\",\n  \"must_change_password\": true\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/reset-password"
          }
        },
        {
          "name": "Force Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}/force-logout"
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}/deactivate"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/roles"
          }
        },
        {
          "name": "List Roles (service key)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Service-Key", "value": "{{serviceKey}}" }],
            "url": "{{baseUrl}}/roles"
          }
        },
        {
          "name": "Get Role",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/roles/{{roleId}}"
          }
        },
        {
          "name": "Create Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('roleId', pm.response.json().data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"custom_role\",\n  \"display_name\": \"Custom Role\",\n  \"description\": \"Example custom role\"\n}"
            },
            "url": "{{baseUrl}}/roles"
          }
        },
        {
          "name": "Update Role",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"Custom Role (updated)\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": "{{baseUrl}}/roles/{{roleId}}"
          }
        },
        {
          "name": "Sync Role Permissions",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission_ids\": [1, 2, 3]\n}"
            },
            "url": "{{baseUrl}}/roles/{{roleId}}/permissions"
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/roles/{{roleId}}"
          }
        }
      ]
    },
    {
      "name": "Permissions",
      "item": [
        {
          "name": "List Permissions",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/permissions?domain=identity",
              "host": ["{{baseUrl}}"],
              "path": ["permissions"],
              "query": [{ "key": "domain", "value": "identity" }]
            }
          }
        }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/audit-logs?per_page=25",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"],
              "query": [
                { "key": "per_page", "value": "25" },
                { "key": "user_id", "value": "", "disabled": true },
                { "key": "event", "value": "login.success", "disabled": true },
                { "key": "from", "value": "2026-01-01T00:00:00Z", "disabled": true },
                { "key": "to", "value": "2026-12-31T23:59:59Z", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "List Audit Logs (service key)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Service-Key", "value": "{{serviceKey}}" }],
            "url": "{{baseUrl}}/audit-logs"
          }
        }
      ]
    }
  ]
}
