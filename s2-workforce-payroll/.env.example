APP_NAME=WH-S2-Workforce
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://s2-workforce:9002

APP_VERSION=1.0

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=wh-mysql
DB_PORT=3306
DB_DATABASE=wh_s2_db
DB_USERNAME=wh_app
DB_PASSWORD=wh_app_secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=sync

REDIS_CLIENT=phpredis
REDIS_HOST=wh-redis
REDIS_PORT=6379

REDIS_BUS_HOST=wh-redis-bus
REDIS_BUS_PORT=6379

INTERNAL_KEY_CURRENT=dev-internal-key-change-in-prod
INTERNAL_KEY_PREVIOUS=

S1_SERVICE_URL=http://s1-identity:9001
S4_SERVICE_URL=http://s4-finance-bi:9004

PAYROLL_EMPLOYEE_PENSION_RATE=0.07
PAYROLL_EMPLOYER_PENSION_RATE=0.11
PAYROLL_INCOME_TAX_RATE=0.15
